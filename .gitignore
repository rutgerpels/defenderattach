# =============================================================
# CUSTOMER DATA — NEVER COMMIT
# These patterns are intentionally broad so a misplaced file in a
# new folder still gets blocked. The repo is private, but treat the
# data as if the repo were public.
# =============================================================
*.xlsx
*.xls
*.xlsm
*.csv
*.tsv
*.pptx
*.ppt
*.bak
*.log
*.tmp

# Test golden oracles derived from customer data (regenerate locally via
# scripts/gen_sl_golden.py). Never commit — they contain customer names + ACR.
web-app/tests/sl-golden.json
*-golden.json

# input/output folders — keep the directory shape (via .gitkeep)
# but never the data files inside them.
inputfolder/*
!inputfolder/.gitkeep
inputfolder_opty/*
!inputfolder_opty/.gitkeep
output/*
!output/.gitkeep

# =============================================================
# SECRETS
# =============================================================
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
secrets.*

# =============================================================
# PYTHON
# =============================================================
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# =============================================================
# NODE (for web-app tests)
# =============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================
# EDITORS / OS
# =============================================================
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# =============================================================
# COPILOT / LOCAL TOOLING
# =============================================================
.copilot/
